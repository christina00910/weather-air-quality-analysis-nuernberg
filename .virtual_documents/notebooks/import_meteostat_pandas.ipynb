


from datetime import datetime
import pandas as pd
from meteostat import daily

def fetch_weather_data():
    start = datetime(2023, 1, 1)
    end = datetime(2023, 12, 31)

    # 1. Wir nutzen jetzt EXAKTE STATION-IDS statt fehleranfälliger GPS-Punkte!
    stations = {
        "München": '10865',
        "Essen": '10410',
        "Schleswig": '10035'
    }

    all_data = []

    print("Starte robusten Wetter-Download über Station-IDs...")

    for city, station_id in stations.items():
        print(f"Lade Daten für {city} (Station {station_id})...")
        
        # daily direkt mit der Stations-ID abfragen
        data = daily(station_id, start, end).fetch()
        
        # 2. Die doppelte Absicherung gegen "Nichts" (None) und leere Tabellen
        if data is not None and not data.empty:
            data = data.reset_index()
            data['Stadt'] = city
            all_data.append(data)
        else:
            print(f"-> Achtung: Keine Daten für {city} gefunden. Überspringe...")

    # ... (vorheriger Code bleibt gleich) ...

    if all_data:
        # Alle Tabellen zusammenkleben
        final_df = pd.concat(all_data, ignore_index=True)
        
        print("\n-> Info: Diese Spalten hat die API tatsächlich geliefert:")
        print(final_df.columns.tolist())
        
        # 3. KUGELSICHERER FILTER:
        # Wir fragen nur nach Spalten, die auch WIRKLICH im Datensatz existieren
        desired_columns = ['time', 'Stadt', 'tavg', 'tmin', 'tmax', 'prcp', 'wspd']
        existing_columns = [col for col in desired_columns if col in final_df.columns]
        
        final_df = final_df[existing_columns]
        
        # 4. Spalten sicher umbenennen (nur die, die da sind)
        rename_dict = {
            'time': 'Datum',
            'tavg': 'Temperatur_Avg',
            'tmin': 'Temperatur_Min',
            'tmax': 'Temperatur_Max',
            'prcp': 'Niederschlag_mm',
            'wspd': 'Wind_kmh'
        }
        # Fehler ignorieren, falls eine Spalte zum Umbenennen fehlt
        final_df.rename(columns=rename_dict, inplace=True, errors='ignore') 
        
        print("\nDownload abgeschlossen! Datenaufbereitung erfolgreich.")
        return final_df
    else:
        print("\nFehler: Es konnten gar keine Daten geladen werden.")
        return None

# ==========================================
# TESTLAUF
# ==========================================
if __name__ == "__main__":
    wetter_df = fetch_weather_data()
    
    if wetter_df is not None:
        print("\nHier sind die ersten 5 Zeilen unseres neuen Datensatzes:")
        display(wetter_df.head())

